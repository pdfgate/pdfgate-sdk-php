{
  "name": "pdfgate/pdfgate-sdk-php",
  "description": "Official PDFGate PHP SDK",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^7.4 || ^8.0",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "PdfGate\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PdfGate\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpdbg -qrr vendor/bin/phpunit --testsuite unit --coverage-text --coverage-clover build/coverage/clover.xml",
    "stan": "phpstan analyse"
  }
}
