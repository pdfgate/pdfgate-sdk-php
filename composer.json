{
  "name": "pdfgate/pdfgate-sdk-php",
  "description": "Official PDFGate PHP SDK",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "pdf",
    "pdfgate",
    "sdk",
    "api"
  ],
  "homepage": "https://pdfgate.com",
  "support": {
    "docs": "https://pdfgate.github.io/pdfgate-sdk-php/",
    "issues": "https://github.com/pdfgate/pdfgate-sdk-php/issues",
    "source": "https://github.com/pdfgate/pdfgate-sdk-php"
  },
  "authors": [
    {
      "name": "PDFGate",
      "homepage": "https://pdfgate.com"
    }
  ],
  "require": {
    "php": "^7.4 || ^8.0",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "PdfGate\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PdfGate\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite unit",
    "test:acceptance": "phpunit --testsuite acceptance",
    "test:coverage": "phpdbg -qrr vendor/bin/phpunit --testsuite unit --coverage-text --coverage-clover build/coverage/clover.xml",
    "docs:api": "php scripts/generate-api-docs.php",
    "docs:check-links": "php scripts/validate-doc-links.php",
    "docs:build": [
      "@docs:api",
      "@docs:check-links"
    ],
    "stan": "phpstan analyse",
    "check": [
      "composer validate --strict",
      "@stan",
      "@test:unit",
      "@docs:check-links"
    ]
  }
}
